{
  "name": "torchbearing-plugin",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "webpack --config webpack.config.mjs",
    "build:check": "webpack configtest --config webpack.config.mjs",
    "typecheck": "tsc --noEmit --project tsconfig.json",
    "typecheck:config": "tsc --showConfig --project tsconfig.json",
    "lint": "eslint --max-warnings 0 .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "jest --passWithNoTests",
    "test:ci": "jest --runInBand --passWithNoTests",
    "metadata:check": "npm run build:check && npm run typecheck:config && npm run lint && npm run format:check && npm run test:ci"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "npm@10.9.8",
  "dependencies": {
    "@grafana/data": "13.0.2",
    "@grafana/runtime": "13.0.2",
    "@grafana/ui": "13.0.2",
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "devDependencies": {
    "@swc/core": "^1.15.0",
    "@swc/jest": "^0.2.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^24.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.38.0",
    "@typescript-eslint/parser": "^8.38.0",
    "copy-webpack-plugin": "^14.0.0",
    "eslint": "^9.32.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "prettier": "^3.6.0",
    "swc-loader": "^0.2.0",
    "typescript": "5.9.2",
    "webpack": "^5.101.0",
    "webpack-cli": "^6.0.0"
  }
}
