# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool, specifically when used with LiteIDE
*.out

# Dependency directories (remove the comment below to include it)
# vendor/
node_modules/

# Go workspace file
go.work
go.work.sum

# env file
.env
.env.*
!.env.example

# the result of the go build
output*
output/*
bin/
dist/
coverage/
plugin/dist/
plugin/coverage/
plugin/.eslintcache
plugin/playwright-report/
plugin/test-results/

# Files generated by IDEs
.idea/
*.iml

# Vim swap files
*.swp

# Vscode files
.vscode
.DS_Store

# Trae files
.trae
*.log
*.log.*
log/
CLAUDE.md

*.jsonl
*.txt


/exclude/
